{
  "name": "nunziellasalluce.com",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint 'app/**/*.{css,scss,vue}'",
    "lint:css:fix": "stylelint 'app/**/*.{css,scss,vue}' --fix",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#dist' '#archive'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules' '#dist' '#archive'",
    "typecheck": "vue-tsc --noEmit",
    "lint:all": "yarn lint && yarn lint:css && yarn lint:md && yarn typecheck",
    "format": "prettier --write .",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@vueuse/core": "14.3.0",
    "@vueuse/nuxt": "14.3.0",
    "bulma": "0.9.4",
    "lazysizes": "5.3.2",
    "nuxt": "4.4.8",
    "scrollama": "3.2.0",
    "splitting": "1.1.0",
    "swiper": "14.0.2",
    "vue": "3.5.39",
    "vue-router": "5.1.0"
  },
  "volta": {
    "node": "24.13.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write",
      "node -e \"require('child_process').execSync('npx yarn typecheck', { stdio: 'inherit' })\""
    ],
    "*.vue": [
      "eslint --fix",
      "stylelint --fix",
      "prettier --write",
      "node -e \"require('child_process').execSync('npx yarn typecheck', { stdio: 'inherit' })\""
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@nuxt/eslint": "1.16.0",
    "@nuxt/test-utils": "4.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "@vue/test-utils": "2.4.11",
    "eslint": "10.6.0",
    "happy-dom": "20.10.6",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "markdownlint-cli2": "0.23.0",
    "postcss-html": "1.8.1",
    "postcss-responsive-type": "1.0.0",
    "prettier": "3.9.5",
    "sass": "1.101.0",
    "stylelint": "17.14.0",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-standard-scss": "17.0.0",
    "typescript": "5.6.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  }
}
