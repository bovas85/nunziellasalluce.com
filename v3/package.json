{
  "name": "v3",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint 'app/**/*.{css,scss,vue}'",
    "lint:css:fix": "stylelint 'app/**/*.{css,scss,vue}' --fix",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules' '#dist'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules' '#dist'",
    "prepare": "husky"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "bulma": "^0.9.2",
    "lazysizes": "^5.3.2",
    "nuxt": "^4.4.8",
    "splitting": "^1.1.0",
    "swiper": "^14.0.2",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "volta": {
    "node": "24.13.0"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --fix",
    "*.{css,scss,vue}": "stylelint --fix",
    "*.md": "markdownlint-cli2 --fix"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.23.0",
    "postcss-html": "^1.8.1",
    "postcss-responsive-type": "^1.0.0",
    "sass": "^1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended-vue": "^1.6.1",
